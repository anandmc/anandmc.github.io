{
  "name": "owl-app",
  "version": "1.0.0",
  "description": "git hub webpage runs on owl",
  "homepage": "https://anandmc.github.io/owl-app",
  "main": "index.js",
  "scripts": {
    "start": "npx parcel src/index.html",
    "build": "npx parcel build public/index.html --out-dir build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "repository": {
    "type": "git",
    "url": "owl-app"
  },
